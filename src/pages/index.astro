---
import Layout from '../layouts/Layout.astro';

// Datos de WhatsApp centralizados
const waLink = "https://wa.link/oz6i43";
---

<Layout title="Synergia Consultores Integrales | Innovación y Estrategia" description="Democratizamos el acceso a servicios legales, educativos, operativos y tecnológicos, conectando la innovación con la ética y responsabilidad social.">
  
  <!-- HEADER / NAVBAR -->
  <header class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-sm border-b border-slate-200 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex-shrink-0">
          <!-- TODO: Update logo to a real path if available -->
          <img src="/img/logo-placeholder.svg" alt="Synergia Logo" class="h-12 w-auto" onerror="this.src='https://placehold.co/150x48/00baff/ffffff?text=SYNERGIA'" />
        </div>
        <nav class="hidden md:flex space-x-8">
          <a href="#inicio" class="text-slate-700 hover:text-blue-500 font-medium transition-colors">Inicio</a>
          <a href="#quienes" class="text-slate-700 hover:text-blue-500 font-medium transition-colors">Quiénes Somos</a>
          <a href="#servicios" class="text-slate-700 hover:text-blue-500 font-medium transition-colors">Servicios</a>
          <a href="#contacto" class="text-slate-700 hover:text-blue-500 font-medium transition-colors">Contacto</a>
        </nav>
        <div class="hidden md:flex">
          <a href={waLink} target="_blank" class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-2.5 rounded-full font-semibold shadow-lg shadow-blue-500/30 transition-all transform hover:scale-105 flex items-center gap-2">
            <i class="fab fa-whatsapp text-lg"></i> Asesoría
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- HERO SECTION -->
  <section id="inicio" class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-slate-50">
    <!-- Background decorations -->
    <div class="absolute inset-0 bg-dots-pattern opacity-50 -z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-white via-slate-50/80 to-blue-50 -z-10"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-block py-1 px-3 rounded-full bg-blue-50 border border-blue-200 text-blue-700 font-bold text-xs mb-6 tracking-wide uppercase shadow-sm">Innovation & Strategy</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-slate-900 tracking-tight leading-tight mb-8">
          Consultoría que <span class="text-blue-600">Transforma Vidas</span>
        </h1>
        <p class="mt-4 text-xl md:text-2xl text-slate-600 mb-10 leading-relaxed font-light">
          Democratizamos el acceso a servicios <strong class="font-semibold">legales, educativos, operativos y tecnológicos</strong>, conectando la innovación con la ética y responsabilidad social.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href={waLink} target="_blank" class="px-8 py-4 bg-blue-500 hover:bg-blue-600 text-white rounded-full font-bold text-lg shadow-xl shadow-blue-500/40 transition-all transform hover:-translate-y-1 flex items-center justify-center gap-2">
            <i class="fab fa-whatsapp text-2xl"></i> Habla con un Experto
          </a>
          <a href="#servicios" class="px-8 py-4 bg-white border-2 border-slate-200 hover:border-slate-300 text-slate-700 rounded-full font-bold text-lg transition-all flex items-center justify-center gap-2">
            Ver Servicios <i class="fas fa-arrow-down"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO SECTION -->
  <section class="py-12 bg-white relative">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl overflow-hidden shadow-2xl border border-slate-200 bg-white group relative">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-start p-8 pointer-events-none">
          <h3 class="text-white text-2xl font-bold">Video Corporativo</h3>
        </div>
        <video controls class="w-full h-auto aspect-video object-cover" poster="/img/quienes-somos.svg">
          <source src="/videos/video.webm" type="video/webm">
          <source src="/videos/video.mp4" type="video/mp4">
          Tu navegador no soporta vídeo.
        </video>
      </div>
    </div>
  </section>

  <!-- QUIÉNES SOMOS -->
  <section id="quienes" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-blue-400 to-cyan-300 rounded-[2rem] transform rotate-3 opacity-20 blur-lg"></div>
          <img src="/img/quienes-somos.svg" alt="Quiénes Somos" class="relative rounded-3xl shadow-xl w-full object-cover bg-white p-8" onerror="this.src='https://placehold.co/600x400/fff/00baff?text=Quienes+Somos'"/>
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="text-4xl font-bold text-slate-900 mb-6">¿Quiénes <span class="text-blue-500">Somos?</span></h2>
          <div class="space-y-6 text-lg text-slate-600">
            <p>
              En <strong class="text-slate-900">Synergia Consultores Integrales Innovation & Strategy S.A.S.</strong> transformamos la consultoría tradicional con soluciones innovadoras, eficientes y socialmente conscientes.
            </p>
            <p>
              Democratizamos el acceso a servicios legales, educativos y tecnológicos de alta calidad, rompiendo la barrera de la exclusión para que cualquier persona o empresa pueda prosperar en la era digital.
            </p>
            <p>
              Actuamos con ética, compromiso e innovación para impulsar el crecimiento real y sostenible de nuestros clientes y comunidades.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS GRID -->
  <section id="servicios" class="py-24 bg-slate-50 relative overflow-hidden border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4 tracking-tight">Nuestras Soluciones</h2>
        <p class="text-xl text-slate-600 max-w-2xl mx-auto">Áreas de especialización diseñadas para cubrir todas las necesidades de tu vida y negocio.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Legal -->
        <div class="bg-white border border-slate-200 shadow-sm hover:shadow-xl p-8 rounded-3xl transition-all duration-300">
          <div class="mb-6 rounded-2xl overflow-hidden bg-slate-50 p-4 flex justify-center border border-slate-100">
            <img src="/img/consultoria-legal.svg" alt="Consultoría Legal" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4 tracking-tight">Consultoría Legal</h3>
          <ul class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Derechos de petición, acciones de tutela, PQRs</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Protección de derechos fundamentales</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Derecho civil y familiar: alimentos, divorcios</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Constitución y formalización de MIPYMES</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Contratos y asesoría comercial</span></li>
          </ul>
        </div>

        <!-- Tecnológica -->
        <div class="bg-blue-600 border border-blue-500 shadow-lg shadow-blue-600/20 p-8 rounded-3xl transition-all duration-300">
          <div class="mb-6 rounded-2xl overflow-hidden bg-white/10 p-4 flex justify-center">
            <img src="/img/consultoria-tecnologica.svg" alt="Consultoría Tecnológica" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">Consultoría Tecnológica</h3>
          <ul class="space-y-3 text-blue-50 font-medium">
            <li class="flex items-start gap-3"><i class="fas fa-check text-white mt-1"></i><span>Transformación digital para MIPYMES</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-white mt-1"></i><span>Automatización e Inteligencia Artificial (IA)</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-white mt-1"></i><span>Desarrollo de sitios web y correo profesional</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-white mt-1"></i><span>Implementación de chatbots avanzados</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-white mt-1"></i><span>Capacitación y gestión de datos</span></li>
          </ul>
        </div>

        <!-- Educativa -->
        <div class="bg-white border border-slate-200 shadow-sm hover:shadow-xl p-8 rounded-3xl transition-all duration-300">
          <div class="mb-6 rounded-2xl overflow-hidden bg-slate-50 p-4 flex justify-center border border-slate-100">
            <img src="/img/consultoria-educativa.svg" alt="Consultoría Educativa" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4 tracking-tight">Consultoría Educativa</h3>
          <ul class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Validación académica y acceso a educación</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Orientación vocacional y proyecto de vida</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Conexión con becas y financiamiento</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Mentoría personalizada</span></li>
          </ul>
        </div>

        <!-- Outsourcing -->
        <div class="bg-white border border-slate-200 shadow-sm hover:shadow-xl p-8 rounded-3xl transition-all duration-300">
          <div class="mb-6 rounded-2xl overflow-hidden bg-slate-50 p-4 flex justify-center border border-slate-100">
            <img src="/img/Outsourcing-Logístico.svg" alt="Outsourcing Logístico" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4 tracking-tight">Outsourcing Logístico</h3>
          <ul class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Selección y supervisión de equipos de campo</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Gestión documental y optimización logística</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-blue-500 mt-1"></i><span>Control y reportes en tiempo real</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-blue-600 relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 tracking-tight">¡Tú también puedes ser parte del cambio!</h2>
      <a href={waLink} target="_blank" class="inline-flex items-center gap-3 px-10 py-5 bg-[#25D366] text-white hover:bg-[#20b858] rounded-full font-bold text-xl shadow-lg transition-transform hover:scale-105">
        <i class="fab fa-whatsapp text-3xl"></i> Contáctanos ahora
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="contacto" class="bg-white border-t border-slate-200 text-slate-500 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 border-b border-slate-200 pb-12 mb-8">
        <div>
          <img src="/img/logo-placeholder.svg" alt="Synergia Logo" class="h-12 w-auto mb-6 opacity-80 transition-all" onerror="this.src='https://placehold.co/150x48/00baff/ffffff?text=SYNERGIA'" />
          <p class="text-sm">Innovación, Estrategia y Responsabilidad Social.</p>
        </div>
        <div>
          <h4 class="text-slate-900 font-bold mb-4 uppercase tracking-wider text-sm">Contacto</h4>
          <ul class="space-y-3">
            <li><a href="tel:+573104444485" class="hover:text-blue-600 transition-colors"><i class="fas fa-phone mr-2"></i> 310 444 4485</a></li>
            <li><a href="mailto:synergiaconsultoresintegrales@gmail.com" class="hover:text-blue-600 transition-colors"><i class="fas fa-envelope mr-2"></i> Enviar Email</a></li>
            <li><a href="https://synergiaconsultores.dpdns.org" class="hover:text-blue-600 transition-colors"><i class="fas fa-globe mr-2"></i> synergiaconsultores.dpdns.org</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-slate-900 font-bold mb-4 uppercase tracking-wider text-sm">Legal</h4>
          <ul class="space-y-3">
            <li><a href="#" class="hover:text-blue-600 transition-colors">Términos y Condiciones</a></li>
            <li><a href="#" class="hover:text-blue-600 transition-colors">Política de Privacidad</a></li>
          </ul>
        </div>
      </div>
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-sm">&copy; {new Date().getFullYear()} Synergia Consultores S.A.S. Todos los derechos reservados.</p>
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a href="#" class="text-slate-400 hover:text-blue-600 transition-colors"><i class="fab fa-facebook-f text-xl"></i></a>
          <a href="#" class="text-slate-400 hover:text-blue-600 transition-colors"><i class="fab fa-instagram text-xl"></i></a>
        </div>
      </div>
    </div>
  </footer>

  <!-- FAB WSP -->
  <a href={waLink} target="_blank" class="fixed bottom-6 right-6 bg-[#25D366] hover:bg-[#20b858] text-white w-14 h-14 rounded-full shadow-lg flex items-center justify-center text-3xl z-50 hover:scale-110 transition-transform">
    <i class="fab fa-whatsapp"></i>
  </a>
</Layout>
