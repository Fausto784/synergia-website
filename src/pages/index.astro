---
import Layout from '../layouts/Layout.astro';

// Datos de WhatsApp centralizados
const waLink = "https://wa.link/oz6i43";
---

<Layout title="Synergia Consultores Integrales | Innovación y Estrategia" description="Democratizamos el acceso a servicios legales, educativos, operativos y tecnológicos, conectando la innovación con la ética y responsabilidad social.">
  
  <!-- HEADER / NAVBAR -->
  <header class="fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-7xl z-50 dark-glass rounded-2xl transition-all duration-300 shadow-[0_10px_30px_rgba(0,0,0,0.5)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16 sm:h-20">
        <div class="flex-shrink-0">
          <!-- TODO: Update logo to a real path if available -->
          <img src="/img/logo-placeholder.svg" alt="Synergia Logo" class="h-10 sm:h-12 w-auto" onerror="this.src='https://placehold.co/150x48/0a0f1e/ffffff?text=SYNERGIA'" />
        </div>
        <nav class="hidden md:flex space-x-8">
          <a href="#inicio" class="text-slate-300 hover:text-cyan-400 font-medium transition-colors">Inicio</a>
          <a href="#quienes" class="text-slate-300 hover:text-cyan-400 font-medium transition-colors">Quiénes Somos</a>
          <a href="#servicios" class="text-slate-300 hover:text-cyan-400 font-medium transition-colors">Servicios</a>
          <a href="#contacto" class="text-slate-300 hover:text-cyan-400 font-medium transition-colors">Contacto</a>
        </nav>
        <div class="hidden md:flex">
          <a href={waLink} target="_blank" class="bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-slate-950 px-6 py-2 rounded-full font-bold shadow-lg shadow-cyan-500/20 transition-all transform hover:scale-105 flex items-center gap-2">
            <i class="fab fa-whatsapp text-lg"></i> Asesoría
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- HERO SECTION -->
  <section id="inicio" class="relative pt-36 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-[#0b0f19]">
    <!-- Background decorations -->
    <div class="absolute inset-0 bg-dots-pattern opacity-10 -z-10"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] radial-glow-cyan blur-3xl -z-10 opacity-70"></div>
    <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] radial-glow-blue blur-3xl -z-10 opacity-50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0b0f19]/50 to-[#0b0f19] -z-10"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-block py-1.5 px-4 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 font-bold text-xs mb-6 tracking-wider uppercase shadow-[0_0_15px_rgba(6,182,212,0.1)]">Innovation & Strategy</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight leading-tight mb-8">
          Consultoría que <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-500 to-indigo-400">Transforma Vidas</span>
        </h1>
        <p class="mt-4 text-xl md:text-2xl text-slate-300 mb-10 leading-relaxed font-light">
          Democratizamos el acceso a servicios <strong class="font-semibold text-white">legales, educativos, operativos y tecnológicos</strong>, conectando la innovación con la ética y responsabilidad social.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href={waLink} target="_blank" class="px-8 py-4 bg-[#25D366] hover:bg-[#20b858] text-white rounded-full font-bold text-lg shadow-xl shadow-emerald-500/20 transition-all transform hover:-translate-y-1 flex items-center justify-center gap-2">
            <i class="fab fa-whatsapp text-2xl"></i> Habla con un Experto
          </a>
          <a href="#servicios" class="px-8 py-4 bg-slate-900/60 border border-slate-800 hover:border-slate-700 text-slate-300 rounded-full font-bold text-lg transition-all backdrop-blur-sm flex items-center justify-center gap-2 hover:-translate-y-1 hover:text-white">
            Ver Servicios <i class="fas fa-arrow-down"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO SECTION -->
  <section class="py-12 bg-[#0b0f19] relative">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl overflow-hidden shadow-2xl shadow-cyan-500/5 border border-slate-800/80 bg-slate-900/40 group relative backdrop-blur-sm p-1">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-start p-8 pointer-events-none">
          <h3 class="text-white text-2xl font-bold tracking-tight">Video Corporativo</h3>
        </div>
        <video controls class="w-full h-auto aspect-video object-cover rounded-2xl" poster="/img/quienes-somos.svg">
          <source src="/videos/video.webm" type="video/webm">
          <source src="/videos/video.mp4" type="video/mp4">
          Tu navegador no soporta vídeo.
        </video>
      </div>
    </div>
  </section>

  <!-- QUIÉNES SOMOS -->
  <section id="quienes" class="py-24 bg-gradient-to-b from-[#0b0f19] to-[#080b11] relative overflow-hidden">
    <!-- Glow effect behind image -->
    <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[350px] h-[350px] bg-cyan-500/10 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-[2rem] transform rotate-3 opacity-30 blur-2xl"></div>
          <img src="/img/quienes-somos.svg" alt="Quiénes Somos" class="relative rounded-3xl shadow-2xl w-full object-cover bg-slate-900/60 p-8 border border-slate-800/50 backdrop-blur-sm" onerror="this.src='https://placehold.co/600x400/0d1425/06b6d4?text=Quienes+Somos'"/>
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="text-4xl font-bold text-white mb-6">¿Quiénes <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Somos?</span></h2>
          <div class="space-y-6 text-lg text-slate-300">
            <p>
              En <strong class="text-white font-semibold">Synergia Consultores Integrales Innovation & Strategy S.A.S.</strong> transformamos la consultoría tradicional con soluciones innovadoras, eficientes y socialmente conscientes.
            </p>
            <p>
              Democratizamos el acceso a servicios legales, educativos y tecnológicos de alta calidad, rompiendo la barrera de la exclusión para que cualquier persona o empresa pueda prosperar en la era digital.
            </p>
            <p>
              Actuamos con ética, compromiso e innovación para impulsar el crecimiento real y sostenible de nuestros clientes y comunidades.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS GRID -->
  <section id="servicios" class="py-24 bg-gradient-to-b from-[#080b11] via-[#0b0f19] to-[#080b11] relative overflow-hidden border-y border-slate-900">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] radial-glow-cyan blur-3xl -z-10 opacity-30"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Nuestras Soluciones</h2>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto font-light">Áreas de especialización diseñadas para cubrir todas las necesidades de tu vida y negocio.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Legal -->
        <div class="glass hover:bg-slate-900/40 border border-slate-800/80 shadow-md hover:shadow-cyan-500/5 p-8 rounded-3xl transition-all duration-300 hover:scale-[1.02]">
          <div class="mb-6 rounded-2xl overflow-hidden bg-slate-950/80 p-4 flex justify-center border border-slate-800/60">
            <img src="/img/consultoria-legal.svg" alt="Consultoría Legal" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">Consultoría Legal</h3>
          <ul class="space-y-3 text-slate-300">
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Derechos de petición, acciones de tutela, PQRs</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Protección de derechos fundamentales</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Derecho civil y familiar: alimentos, divorcios</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Constitución y formalización de MIPYMES</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Contratos y asesoría comercial</span></li>
          </ul>
        </div>

        <!-- Tecnológica (Destacado con glow-border) -->
        <div class="glow-border p-8 rounded-3xl transition-all duration-300 hover:scale-[1.02] shadow-[0_0_40px_rgba(6,182,212,0.15)] flex flex-col justify-between">
          <div>
            <div class="mb-6 rounded-2xl overflow-hidden bg-slate-950/80 p-4 flex justify-center border border-slate-800/60">
              <img src="/img/consultoria-tecnologica.svg" alt="Consultoría Tecnológica" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
            </div>
            <h3 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-400 mb-4 tracking-tight">Consultoría Tecnológica</h3>
            <ul class="space-y-3 text-slate-200">
              <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Transformación digital para MIPYMES</span></li>
              <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Automatización e Inteligencia Artificial (IA)</span></li>
              <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Desarrollo de sitios web y correo profesional</span></li>
              <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Implementación de chatbots avanzados</span></li>
              <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Capacitación y gestión de datos</span></li>
            </ul>
          </div>
        </div>

        <!-- Educativa -->
        <div class="glass hover:bg-slate-900/40 border border-slate-800/80 shadow-md hover:shadow-cyan-500/5 p-8 rounded-3xl transition-all duration-300 hover:scale-[1.02]">
          <div class="mb-6 rounded-2xl overflow-hidden bg-slate-950/80 p-4 flex justify-center border border-slate-800/60">
            <img src="/img/consultoria-educativa.svg" alt="Consultoría Educativa" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">Consultoría Educativa</h3>
          <ul class="space-y-3 text-slate-300">
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Validación académica y acceso a educación</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Orientación vocacional y proyecto de vida</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Conexión con becas y financiamiento</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Mentoría personalizada</span></li>
          </ul>
        </div>

        <!-- Outsourcing -->
        <div class="glass hover:bg-slate-900/40 border border-slate-800/80 shadow-md hover:shadow-cyan-500/5 p-8 rounded-3xl transition-all duration-300 hover:scale-[1.02]">
          <div class="mb-6 rounded-2xl overflow-hidden bg-slate-950/80 p-4 flex justify-center border border-slate-800/60">
            <img src="/img/Outsourcing-Logístico.svg" alt="Outsourcing Logístico" class="w-full h-48 object-contain hover:scale-105 transition-transform duration-300" />
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">Outsourcing Logístico</h3>
          <ul class="space-y-3 text-slate-300">
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Selección y supervisión de equipos de campo</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Gestión documental y optimización logística</span></li>
            <li class="flex items-start gap-3"><i class="fas fa-check text-cyan-400 mt-1"></i><span>Control y reportes en tiempo real</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-[#0b0f19] via-[#0e1629] to-[#0b0f19] relative overflow-hidden border-b border-slate-900">
    <div class="absolute inset-0 radial-glow-cyan blur-3xl opacity-30 -z-10"></div>
    <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 tracking-tight">¡Tú también puedes ser parte del cambio!</h2>
      <a href={waLink} target="_blank" class="inline-flex items-center gap-3 px-10 py-5 bg-[#25D366] text-white hover:bg-[#20b858] rounded-full font-bold text-xl shadow-[0_0_30px_rgba(37,211,102,0.3)] transition-transform hover:scale-105">
        <i class="fab fa-whatsapp text-3xl"></i> Contáctanos ahora
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="contacto" class="bg-[#080b11] border-t border-slate-900 text-slate-400 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 border-b border-slate-800/60 pb-12 mb-8">
        <div>
          <img src="/img/logo-placeholder.svg" alt="Synergia Logo" class="h-12 w-auto mb-6 opacity-85 transition-all" onerror="this.src='https://placehold.co/150x48/080b11/ffffff?text=SYNERGIA'" />
          <p class="text-sm">Innovación, Estrategia y Responsabilidad Social.</p>
        </div>
        <div>
          <h4 class="text-slate-200 font-bold mb-4 uppercase tracking-wider text-sm">Contacto</h4>
          <ul class="space-y-3">
            <li><a href="tel:+573104444485" class="hover:text-cyan-400 transition-colors"><i class="fas fa-phone mr-2"></i> 310 444 4485</a></li>
            <li><a href="mailto:synergiaconsultoresintegrales@gmail.com" class="hover:text-cyan-400 transition-colors"><i class="fas fa-envelope mr-2"></i> Enviar Email</a></li>
            <li><a href="https://synergiaconsultores.dpdns.org" class="hover:text-cyan-400 transition-colors"><i class="fas fa-globe mr-2"></i> synergiaconsultores.dpdns.org</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-slate-200 font-bold mb-4 uppercase tracking-wider text-sm">Legal</h4>
          <ul class="space-y-3">
            <li><a href="#" class="hover:text-cyan-400 transition-colors">Términos y Condiciones</a></li>
            <li><a href="#" class="hover:text-cyan-400 transition-colors">Política de Privacidad</a></li>
          </ul>
        </div>
      </div>
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-sm">&copy; {new Date().getFullYear()} Synergia Consultores S.A.S. Todos los derechos reservados.</p>
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a href="#" class="text-slate-500 hover:text-cyan-400 transition-colors"><i class="fab fa-facebook-f text-xl"></i></a>
          <a href="#" class="text-slate-500 hover:text-cyan-400 transition-colors"><i class="fab fa-instagram text-xl"></i></a>
        </div>
      </div>
    </div>
  </footer>

  <!-- FAB WSP -->
  <a href={waLink} target="_blank" class="fixed bottom-6 right-6 bg-[#25D366] hover:bg-[#20b858] text-white w-14 h-14 rounded-full shadow-[0_0_20px_rgba(37,211,102,0.4)] flex items-center justify-center text-3xl z-50 hover:scale-110 transition-transform duration-300">
    <i class="fab fa-whatsapp"></i>
  </a>
</Layout>
